@include('partials/header')

<div class="row mx-3">
    <div class="col-xl-5 col-lg-8 mx-auto">
        <div class="card mt-3">
            <div class="card-header">Новая игра</div>

            <div class="card-body">
                <form action="/game/create" method="POST" id="game-create-form">

                    <div class="mb-3">
                        <label for="name" class="form-label">Название</label>

                        <div class="input-group mb-3">
                            <input id="name" name="name" type="text" class="form-control" required>
                            <button class="btn btn-outline-secondary" type="button" id="generate-game-name-btn">
                                придумать
                            </button>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="player">Участники</label>

                        <div class="input-group mb-3">
                            <select id="player" name="player" class="form-select">
                                @each(user in users)
                                <option value="{{ user.id }}">{{ user.login }}</option>
                                @end
                            </select>

                            <select name="players" id="players" multiple class="d-none"></select>

                            <button class="btn btn-outline-secondary" type="button" id="add-player-btn">
                                добавить
                            </button>
                        </div>

                        <div id="players-list" class="d-none d-flex flex-row gap-3 flex-wrap card card-body"></div>
                    </div>

                    <div class="mb-3">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="isPublic" name="isPublic" value="on"
                                   @if(defaultSettings.isPublic)
                                   checked
                                   @endif
                            >

                            <label class="form-check-label" for="isPublic">
                                видна другим игрокам
                            </label>
                        </div>
                    </div>

                    <div class="mb-3">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="isDebug" name="isDebug" value="on"
                                   @if(defaultSettings.isDebug)
                                   checked
                                   @endif
                            >

                            <label class="form-check-label" for="isDebug">
                                режим отладки (только для специалистов)
                            </label>
                        </div>
                    </div>

                    <div class="mb-3">
                        <div class="form-check">

                            <input class="form-check-input" type="checkbox" value="on" id="withTimeControl"
                                   name="withTimeControl" checked>

                            <label class="form-check-label" for="withTimeControl">
                                контроль времени
                            </label>
                        </div>
                    </div>

                    <div id="time-control-settings">
                        <div class="mb-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="on" id="loseWhenTimeout"
                                       name="loseWhenTimeout"
                                       @if(defaultTimeControlSettings.loseWhenTimeout)
                                       checked
                                       @endif
                                >

                                <label class="form-check-label" for="loseWhenTimeout">
                                    проигрыш по истечению времени
                                </label>
                            </div>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label" for="startTime">Стартовое время (сек.)</label>

                                <input type="number" min="0" id="startTime" name="startTime" class="form-control"
                                       value="{{ defaultTimeControlSettings.startTime }}">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="defaultTimeIncrease">Прибавка времени за ход
                                    (сек.)</label>

                                <input type="number" min="0" id="defaultTimeIncrease" name="defaultTimeIncrease"
                                       class="form-control" value="{{ defaultTimeControlSettings.defaultTimeIncrease}}">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="fightTimeIncrease">Прибавка времени в бою
                                    (сек.)</label>

                                <input type="number" min="0" id="fightTimeIncrease" name="fightTimeIncrease"
                                       class="form-control" value="{{ defaultTimeControlSettings.fightTimeIncrease }}">
                            </div>
                        </div>
                    </div>

                    <div class="mb-0">
                        <button class="btn btn-primary" type="submit" id="submit-btn">Создать</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        let players = [];

        let playersInput = document.getElementById('player');
        let playersList = document.getElementById('players-list');
        let playersInputForm = document.getElementById('players');

        for (let child of playersInput.children) {
            players.push({
                id: child.getAttribute('value'),
                login: child.innerHTML,
                selected: false
            });
        }

        let generateName = () => {
            let randomElement = (array) => {
                let random = Math.random();

                return array[Math.floor(random * array.length)];
            }

            let getDate = () => {
                return new Date().toLocaleDateString('ru-ru', {year: "numeric", month: "numeric", day: "numeric"});
            }

            // 0 - при ..., 1 - у ...
            let locations = [
                ['Марсе', 'Марса'],
                ['Венере', 'Венеры'],
                ['Малой Медведице', 'Малой Медведицы'],
                ['Вердене', 'Вердена'],
                ['Асгарде', 'Асгарда'],
            ]

            let nameGenerators = [
                () => {
                    return 'Битва от ' + getDate();
                },
                () => {
                    return 'Резня от ' + getDate();
                },
                () => {
                    return 'Потасовка ' + getDate();
                },
                () => {
                    return 'Битва при ' + randomElement(locations)[0];
                },
                () => {
                    return 'Последствия пьянства у ' + randomElement(locations)[1];
                },
                () => {
                    return 'Дед с батей подрались у ' + randomElement(locations)[1];
                },
            ];

            return randomElement(nameGenerators)();
        }

        let generateNameBtn = document.getElementById('generate-game-name-btn');
        let nameInput = document.getElementById('name');

        generateNameBtn.addEventListener('click', () => {
            nameInput.value = generateName();
        });

        let updateSelectedPlayers = () => {
            playersList.textContent = '';
            playersInput.textContent = '';
            playersInputForm.textContent = '';

            let hasSelected = false;

            for (let player of players) {
                if (player.selected) {
                    let playerDiv = document.createElement('div');
                    playerDiv.innerHTML = player.login;
                    playerDiv.addEventListener('click', () => {
                        player.selected = false;

                        updateSelectedPlayers();
                    });
                    playerDiv.setAttribute('style', 'cursor: pointer;');
                    playerDiv.setAttribute('title', 'Нажмите, чтобы удалить из списка');

                    playersList.appendChild(playerDiv);

                    //
                    let playerOption = document.createElement('option');
                    playerOption.innerHTML = player.login;
                    playerOption.setAttribute('value', player.id);
                    playerOption.setAttribute('selected', '1');

                    playersInputForm.appendChild(playerOption);

                    hasSelected = true;
                } else {
                    let playerOption = document.createElement('option');
                    playerOption.innerHTML = player.login;
                    playerOption.setAttribute('value', player.id);

                    playersInput.appendChild(playerOption);
                }
            }

            if (hasSelected) {
                playersList.classList.remove('d-none');
            } else {
                playersList.classList.add('d-none')
            }
        };

        let addPlayerButton = document.getElementById('add-player-btn');
        addPlayerButton.onclick = () => {
            let playerInput = document.getElementById('player');

            if (!playerInput.value)
                return;

            let player = players.find(p => p.id === playerInput.value);

            if (!player)
                return;

            player.selected = true;

            let selected = players.filter(p => p.selected);
            if (selected.length < 2 || selected.length > 5) {
                playersInput.setCustomValidity('Должно быть от 2 до 5 игроков');
            } else {
                playersInput.setCustomValidity("");
            }

            updateSelectedPlayers();
        };

        let checkbox = document.getElementById('withTimeControl');
        let timeControlSettings = document.getElementById('time-control-settings');
        checkbox.addEventListener('click', () => {
            if (checkbox.checked) {
                timeControlSettings.classList.remove('d-none')
            } else {
                timeControlSettings.classList.add('d-none');
            }
        });

        document.getElementById('game-create-form').addEventListener('submit', (evt) => {
            let selected = players.filter(p => p.selected);

            if (selected.length < 2 || selected.length > 5) {
                evt.preventDefault();

                playersInput.setCustomValidity('Должно быть от 2 до 5 игроков');
                playersInput.reportValidity();
            }
        });
    });
</script>