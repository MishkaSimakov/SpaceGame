{
  "compilerOptions": {
    "sourceMap": true,
    "outDir": "dist",
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["esnext"],
    "esModuleInterop": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "inlineSourceMap": true,
  },
  "exclude": [
    "node_modules"
  ],
  "include": [
    "./src/**/*"
  ],
  "rootDirs": [
    ".",
    "../common"
  ]
}
