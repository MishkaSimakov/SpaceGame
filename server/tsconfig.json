{
  "compilerOptions": {
    "sourceMap": true,
    "outDir": "dist",
    "target": "es2024",
    "module": "node16",
    "lib": [
      "esnext"
    ],
    "esModuleInterop": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "moduleResolution": "node16",
    "resolveJsonModule": true,
    "inlineSourceMap": true,
    "strict": true,
    "paths": {
      "@common/*": [
        "../common/*"
      ],
      "@src/*": [
        "src/*"
      ]
    }
  },
  "exclude": [
    "node_modules"
  ],
  "include": [
    "./src/**/*",
    "./tests/**/*",
    "../common/**/*"
  ],
  "rootDirs": [
    ".",
    "../common"
  ]
}
